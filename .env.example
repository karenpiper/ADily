# Supabase (get these from Project Settings → API in Supabase Dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Production URL for OAuth redirects (set in Vercel env vars so sign-in redirects to your app, not localhost)
# e.g. https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=
